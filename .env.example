NODE_ENV=development
PORT=3000

# Database
DB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
DB_NAME=voca_dev

# JWT (added in Sprint 02)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=debug
