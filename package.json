{
  "name": "voca-server",
  "version": "0.1.0",
  "description": "Vocabulary learning app server — AI-assisted, personalized word learning platform",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "test:prompts": "vitest run --config experiments/vitest.prompts.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.52.0",
    "cors": "2.8.6",
    "dotenv": "16.5.0",
    "express": "5.1.0",
    "express-rate-limit": "8.3.2",
    "helmet": "8.1.0",
    "mongodb": "7.1.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "uuid": "11.1.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.2",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "8.33.0",
    "@typescript-eslint/parser": "8.33.0",
    "eslint": "9.27.0",
    "pino-pretty": "13.1.3",
    "supertest": "7.1.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.0",
    "vitest": "3.2.1"
  }
}
